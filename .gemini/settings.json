{
  "general": {
    "sessionRetention": {
      "enabled": true,
      "maxAge": "1w",
      "warningAcknowledged": true
    },
    "preferredEditor": "neovim",
    "vimMode": true,
    "enableAutoUpdate": false
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "folderTrust": {
      "enabled": false
    }
  },
  "ui": {
    "theme": "ANSI",
    "inlineThinkingMode": "off",
    "showStatusInTitle": false,
    "dynamicWindowTitle": false,
    "showShortcutsHint": false,
    "hideBanner": true,
    "footer": {
      "hideCWD": true,
      "hideSandboxStatus": true,
      "hideModelInfo": false
    },
    "showMemoryUsage": true,
    "showLineNumbers": false,
    "showUserIdentity": false,
    "useBackgroundColor": true,
    "loadingPhrases": "tips",
    "errorVerbosity": "low",
    "hideWindowTitle": true,
    "hideTips": true,
    "hideContextSummary": true,
    "hideFooter": false
  },
  "output": {
    "format": "text"
  },
  "model": {
    "name": "auto"
  },
  "tools": {
    "shell": {
      "showColor": true
    },
    "truncateToolOutputThreshold": 100000
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "experimental": {
    "directWebFetch": true
  },
  "context": {
    "includeDirectories": [
      "~/.gemini/gems"
    ]
  }
}