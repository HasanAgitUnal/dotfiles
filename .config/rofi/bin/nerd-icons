#!/bin/bash

CACHE_FILE="$HOME/.cache/nerd-fonts-icons.txt"
JSON_URL="https://raw.githubusercontent.com/ryanoasis/nerd-fonts/master/glyphnames.json"

if [ ! -s "$CACHE_FILE" ]; then
    notify-send "Downloading icon set..."
    curl -s "$JSON_URL" | jq -r 'to_entries | .[] | select(.key != "METADATA") | "\(.value.char)   \(.key)"' > "$CACHE_FILE"
fi

selected=$(cat "$CACHE_FILE" | rofi -dmenu -i -p "Select Icon: " -theme-str "* { font: \"CaskaydiaCove Nerd Font 14\"; } window { height : 600; width : 900px; } listview { columns : 5; } element { text-color : #a0a0a0;}")

if [ -n "$selected" ]; then
    icon=$(echo "$selected" | awk '{print $1}')
    
    echo -n "$icon" | wl-copy
    
    notify-send "Copied icon: $icon"
fi
