#!/bin/bash
# ~/.config/rofi/mount/mount

LIST_THEME="$HOME/.config/rofi/list.rasi"
INPUT_THEME="$HOME/.config/rofi/input.rasi"

# Check dependencies
for cmd in rofi sudo jq lsblk; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        notify-send "Error: $cmd is not installed."
        exit 1
    fi
done

# Action Selection
action=$(printf "Mount\nUnmount" | rofi -dmenu -i -p "Action   " -theme "$LIST_THEME")
[ -z "$action" ] && exit

# Filter devices for action
if [ "$action" = "Mount" ]; then
    devices=$(lsblk -Jp -o NAME,FSTYPE,MOUNTPOINT,SIZE,LABEL | jq -r '.. | objects | select(.fstype != null and .mountpoint == null and .fstype != "swap") | "\(.name) (\(.size)) \(.label // "")"' | sed 's/ *$//')
    prompt="Mount   "
else
    devices=$(lsblk -Jp -o NAME,FSTYPE,MOUNTPOINT,SIZE,LABEL | jq -r '.. | objects | select(.mountpoint != null and (.mountpoint | test("/$|/boot|/home|swap|SWAP") | not)) | "\(.name) (\(.size)) [\(.mountpoint)] \(.label // "")"' | sed 's/ *$//')
    prompt="Unmount   "
fi

if [ -z "$devices" ]; then
    rofi -dmenu -i -p "No devices found" -theme "$INPUT_THEME"
    exit
fi

selected=$(echo "$devices" | rofi -dmenu -i -p "$prompt" -theme "$LIST_THEME")
if [ -z "$selected" ] || [ "$selected" = "No devices found" ]; then
    exit
fi

dev_path=$(echo "$selected" | awk '{print $1}')

# Robust metadata extraction
LABEL=""
FSTYPE=""
eval $(lsblk -P -o LABEL,FSTYPE "$dev_path")
[ -z "$LABEL" ] && LABEL=$(basename "$dev_path")
mount_point="/run/media/$USER/$LABEL"

# Get Password
passwd=$(rofi -dmenu -password -i -p "Sudo Password:" -theme "$INPUT_THEME" </dev/null | tr -d '\r\n')
[ -z "$passwd" ] && exit

# Validate password once
auth_res=$(printf '%s\n' "$passwd" | sudo -S -v -p '' 2>&1)
if [ $? -ne 0 ]; then
    msg="Auth Error: $auth_res"
    # Log length for debugging (safe)
    pass_len=${#passwd}
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] Auth Fail | Len: $pass_len | Res: $auth_res" >> /tmp/rofi-mount.log
    printf "Exit" | rofi -dmenu -i -p "$msg" -theme "$INPUT_THEME"
    exit 1
fi

# Mount/Unmount logic
if [ "$action" = "Mount" ]; then
    # Create mount point
    printf '%s\n' "$passwd" | sudo -S -p '' mkdir -p "$mount_point" >/dev/null 2>&1
    printf '%s\n' "$passwd" | sudo -S -p '' chown "$USER:$USER" "$mount_point" >/dev/null 2>&1
    
    # Try mounting
    if [[ "$FSTYPE" == "ntfs" ]] || [[ "$selected" =~ "ntfs" ]]; then
        res=$(printf '%s\n' "$passwd" | sudo -S -p '' mount -t ntfs-3g "$dev_path" "$mount_point" -o "uid=$(id -u),gid=$(id -g)" 2>&1)
    elif [[ "$FSTYPE" =~ ^(exfat|vfat)$ ]] || [[ "$selected" =~ (exfat|vfat) ]]; then
        res=$(printf '%s\n' "$passwd" | sudo -S -p '' mount "$dev_path" "$mount_point" -o "uid=$(id -u),gid=$(id -g)" 2>&1)
    else
        res=$(printf '%s\n' "$passwd" | sudo -S -p '' mount "$dev_path" "$mount_point" 2>&1)
    fi
    status=$?
else
    res=$(printf '%s\n' "$passwd" | sudo -S -p '' umount "$dev_path" 2>&1)
    status=$?
    # Remove empty mount point
    printf '%s\n' "$passwd" | sudo -S -p '' rmdir "$mount_point" >/dev/null 2>&1
fi

# Log output
echo "[$(date '+%Y-%m-%d %H:%M:%S')] Action: $action | Device: $dev_path | Status: $status | Result: $res" >> /tmp/rofi-mount.log

if [ $status -eq 0 ]; then
    msg="Success: $action completed."
else
    msg="Error: $res"
fi

printf "Exit" | rofi -dmenu -i -p "$msg" -theme "$INPUT_THEME"
