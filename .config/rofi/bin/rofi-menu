#!/bin/bash

options="App Launcher\nWifi Manager\nMount Disk\nNerd Font Icons\nEmojis\nPower"
selected=$(echo -ne "$options" | rofi -dmenu -i -p "Select:")

case $selected in
	"App Launcher")
		rofi -show drun
		;;

	"Wifi Manager")
		~/dotfiles/.config/rofi/wifi/wifi
		;;
        "Mount Disk")
                ~/dotfiles/.config/rofi/mount/mount
                ;;
        "Nerd Font Icons")
                ~/dotfiles/.config/rofi/bin/nerd-icons
                ;;
        "Emojis")
                ~/dotfiles/.config/rofi/bin/emoji
                ;;
        "Power")
                ~/dotfiles/.config/rofi/bin/power
                ;;
	*) 
                echo wtf is happening?
                ;;
esac
