#!/bin/bash

options="App Launcher\nWifi Manager\nMount Disk"
selected=$(echo -ne "$options" | rofi -dmenu -i -p "Select:")
which rofi-wifi
# rofi-* scripts are at ~/.local/bin (as a symlink)
case $selected in
	"App Launcher")
		rofi -show drun
		;;

	"Wifi Manager")
		~/dotfiles/.config/rofi/wifi/wifi
		;;
        "Mount Disk")
                ~/dotfiles/.config/rofi/mount/mount
                ;;
	*) 
                echo wtf is happening?
                ;;
esac
