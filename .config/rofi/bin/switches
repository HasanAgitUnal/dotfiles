#!/bin/bash

podman_is_running() {
        podman inspect -f '{{.State.Running}}' "$1" 2>/dev/null | grep -q "true"
}

if [[ $(hyprshade current ) == "night_mode" ]]; then
        NIGHTMODE_SWITCH="  Night Mode"
else
        NIGHTMODE_SWITCH="  Night Mode"
fi

if [[ -f ~/.night_mode_lock ]]; then
        NIGHTMODE_LOCK=1
        echo opened
        NIGHTMODE_LOCK_SWITCH="  Night Mode Lock"
else
        NIGHTMODE_LOCK=0
        echo closed
        NIGHTMODE_LOCK_SWITCH="  Night Mode Lock"
fi

FRESHRSS_YML="/home/melon/selfhost/freshrss/docker-compose.yml"
if podman_is_running freshrss; then
        FRESHRSS=1
        FRESHRSS_SWITCH="  FreshRSS"
else
        FRESHRSS=0
        FRESHRSS_SWITCH="  FreshRSS"
fi

if [[ -n $(ps aux | grep qbittorrent-nox | grep -v grep) ]]; then
        QBIT=1
        QBIT_SWITCH="  qBittorrent"
else
        QBIT=0
        QBIT_SWITCH="  qBittorrent"
fi

MENU="$NIGHTMODE_SWITCH\n$NIGHTMODE_LOCK_SWITCH\n$FRESHRSS_SWITCH\n$QBIT_SWITCH"
SELECTION=$(echo -e "$MENU" | rofi -dmenu -i -p "Switches   ")

case $SELECTION in
        *"Night Mode Lock")
                rm ~/.night_mode_lock || touch ~/.night_mode_lock
                ;;
        *"Night Mode")
                hyprshade toggle night_mode
                ;;
        *"FreshRSS")
                if [[ $FRESHRSS -eq 1 ]]; then
                        podman-compose -f "$FRESHRSS_YML" stop
                else
                        podman freshrss start || podman-compose -f "$FRESHRSS_YML" up -d
                fi
                ;;
        *"qBittorrent")
                if [[ $QBIT -eq 1 ]]; then
                        pkill qbittorrent-nox
                else
                        qbittorrent-nox &
                fi
esac
