#!/bin/bash

# Configuration
LIST_THEME=~/.config/rofi/list.rasi
INPUT_THEME=~/.config/rofi/input.rasi

# Status Icons & Functions
get_status() {
    interface=$(ls /sys/class/net | grep '^wl' | head -n 1)
    if [ -n "$interface" ]; then
        flag=$(cat "/sys/class/net/$interface/flags" 2>/dev/null)
        [ "$flag" = "0x1003" ] && power="’łģ " || power="’łä "
        
        state=$(cat "/sys/class/net/$interface/operstate" 2>/dev/null)
        if [ "$state" = "up" ]; then
            status=$(nmcli -t -f TYPE,NAME connection show --active | grep '^802-11-wireless' | cut -d':' -f2 | head -n 1)
            [ -z "$status" ] && status="Connected"
        else
            status="Disconnected"
        fi
    else
        power="N/A"
        status="No Device"
    fi
}

get_icon() {
    signal=$1
    if [ "$signal" -lt 25 ]; then echo "¾░ż»";
    elif [ "$signal" -lt 50 ]; then echo "¾░ż¤";
    elif [ "$signal" -lt 70 ]; then echo "¾░żó";
    elif [ "$signal" -lt 85 ]; then echo "¾░żź";
    else echo "¾░ż©"; fi
}

connections() {
    notify-send "WiFi" "Scanning for networks..."
    raw_list=$(nmcli -t -f "BARS,SIGNAL,SECURITY,SSID" device wifi list)
    
    # Format list with icons
    formatted_list=""
    while IFS=: read -r bars signal security ssid; do
        [ -z "$ssid" ] && continue
        icon=$(get_icon "$signal")
        lock=$([ "$security" != "--" ] && echo "¾░īŠ" || echo "¾░”×")
        formatted_list+="$icon    $lock    $ssid\n"
    done <<< "$raw_list"

    selected_net=$(printf "$formatted_list" | rofi -dmenu -i -p "Select Network [$status]   " -theme "$LIST_THEME" -theme-str 'window { width: 800px; } listview { columns: 2; spacing: 0px; }')
    [ -z "$selected_net" ] && exit
    
    wifi_name=$(echo "$selected_net" | sed -E 's/^[^ ]+ +[^ ]+ +//')
    is_locked=$(echo "$selected_net" | grep -q "¾░īŠ" && echo "yes" || echo "no")

    if [ "$is_locked" = "yes" ]; then
        pass=$(echo "" | rofi -dmenu -password -i -p "Password for $wifi_name:" -theme "$INPUT_THEME")
        if [[ -z "$pass" ]]; then
                res=$(nmcli device wifi connect "$wifi_name" >&1)
        else
                res=$(nmcli device wifi connect "$wifi_name" password "$pass" 2>&1)
        fi
    else
        res=$(nmcli device wifi connect "$wifi_name" 2>&1)
    fi

    if [ $? -eq 0 ]; then
        notify-send "WiFi" "Connected to $wifi_name"
    else
        notify-send "WiFi Error" "$res"
    fi
}

# Main Menu
get_status
powertoggle=$([ "$power" = "’łģ " ] && echo "’łä  Turn Off" || echo "’łģ  Turn On")

options="$powertoggle\n¾░¢®  Connections\n¾░¢¬  Disconnect\n¾░īī  Manual Connect"
chosen=$(printf "$options" | rofi -dmenu -i -p "WiFi $power   " -theme "$LIST_THEME")

case "$chosen" in
    *Turn\ Off)
            nmcli radio wifi off
            ;;
    *Turn\ On)
            nmcli radio wifi on
            ;;
    *Connections)
            connections
            ;;
    *Disconnect)
            nmcli device disconnect $(nmcli -t -f DEVICE,TYPE device | grep :wifi | cut -d: -f1 | head -n1)
            ;;
    *Manual\ Connect)
        ssid=$(rofi -dmenu -p "SSID:" -theme "$INPUT_THEME")
        [ -z "$ssid" ] && exit
        pass=$(echo "" | rofi -dmenu -password -i -p "Password:" -theme "$INPUT_THEME")
        nmcli device wifi connect "$ssid" password "$pass"
        ;;
esac
