{
        "clock": {
                "format": "{:%H:%M | %d:%m:%Y}",
                "interval": 30,
                "tooltip": false
        },

        "battery": {
                "format": "{icon} %{capacity}",
                "states": {
                        "critical": 15
                },
                "interval": 1,
                "format-icons": {
                        "default": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
                        "charging": ["َ°¢œ", "َ°‚†", "َ°‚‡", "َ°‚ˆ", "َ°¢‌", "َ°‚‰", "َ°¢‍", "َ°‚ٹ", "َ°‚‹", "َ°‚…"]
                }
        },

        "power-profiles-daemon": {
                "format": "{icon}",
                "tooltip-format": "{profile}",
                "format-icons": {
                        "default": "َ±گ‹",
                        "performance": "َ±گ‹",
                        "balanced": "ï‰ژ ",
                        "power-saver": "ïپ¬" //َ°ڑ¥
