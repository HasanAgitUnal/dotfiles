        },

        "memory": {
                "format": "î؟…  %{percentage}",
                "tooltip-format": "RAM:  {used:0.2f}GiB / {total}GiB\nSwap: {swapUsed:0.2f}GiB / {swapTotal}GiB",
                "interval" : 2
        },

        "disk": {
                "format": "ï‚   {free} / {total}",
                "tooltip-format": "Total: {total}\nUsed: {used}\nFree: {free}"
        },

