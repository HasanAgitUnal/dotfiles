        "backlight": {
                "format": "{icon} %{percent}",
                "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
                "tooltip": false
        },

        "pulseaudio": {
                "format": "<span size='12500' rise='-1000'>{icon}</span> %{volume}",
                "format-muted": "<span size='12500' rise='-1000'>َ°‌ں</span>",
                "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"],
                "tooltip": false
        },

        "keyboard-state": {
                "capslock": true,
                "numlock": true,
                "format": {
                        "capslock": "َ°ھ› {icon}",
                        "numlock": "َ°½¾ {icon}"
                },
                "format-icons": {
                        "locked": "ï„‘",
                        "unlocked": "î®µ"
                }
        },

        "cpu": {
                "format": "ï’¼  %{usage}",
