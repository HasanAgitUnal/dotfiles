{
  "session_dirs": [
    "/usr/share/wayland-sessions",
    "/usr/share/xsessions"
  ],
  "custom_sessions": [
    {
      "name": "Shell",
      "exec": "/usr/bin/bash"
    }
  ],
  "monitor_nums": [],
  "form_on_monitors": [],
  "delay_secs": 1,
  "cmd-sleep": "systemctl suspend",
  "cmd-reboot": "systemctl reboot",
  "cmd-poweroff": "systemctl poweroff",
  "gtk-theme": "CybrCyanMateria",
  "gtk-icon-theme": "CybrCyanPapirus",
  "gtk-cursor-theme": "LyraB-cursors",
  "prefer-dark-theme": true,
  "template-name": "",
  "time-format": "%H:%M",
  "date-format": "%d.%m.%y",
  "layer": "overlay",
  "keyboard-mode": "on_demand",
  "lang": "",
  "avatar-show": false,
  "avatar-size": 100,
  "avatar-border-width": 1,
  "avatar-border-color": "#111117",
  "avatar-corner-radius": 15,
  "avatar-circle": false,
  "env-vars": []
}
